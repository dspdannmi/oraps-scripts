function oratab
    {
    if [ "${ORATAB}" != "" ] && [ -f ${ORATAB} ]
    then
        grep -v ^\# ${ORATAB} | grep -v ^\$
    else
        echoerr "ERROR: ORATAB not defined"
        return 1
    fi
    }

