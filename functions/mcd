
function mcd
    {
    if [ $# -gt 1 ]
    then
        echo "ERROR: too many parameters - expecting 1"
        return 1
    fi

    dir=${1}

    if [ -d ${dir} ] || [ -f ${dir} ]
    then
	echo "warn: ${dir} already exists"
    else
	mkdir -p ${dir} || echo "mcd: mkdir error"
    fi

    if [ -d ${dir} ]
    then
	cd ${dir}
    else
	echo "mcd: error: ${dir} does not exist"
    fi
    }


