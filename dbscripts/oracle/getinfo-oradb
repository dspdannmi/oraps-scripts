function display_machine
    {
    echo "<getinfo:oracle_database>"

    echo "timestamp:$(date +%Y%m%d%H%M%S)"

    echo "DSP_DISTRO:${DSP_DISTRO}"
    echo "DSP_WHOAMI:${DSP_WHOAMI}"
    echo "hostname:${HOSTNAME}"
    echo "dspserverid:${dspserverid}"

    if [ -r ${DSP_VERSION_FILE} ]
    then
        echo "dsp_version:$(cat ${DSP_VERSION_FILE})"
    else
        echo "dsp_version:file_not_found"
    fi

    if serverstampcheck 2>&1 > /dev/null
    then
        echo "serverstampcheck:PASS"
    else
        echo "serverstampcheck:FAIL"
    fi

    echo "<dsp_identity_file>"
    if [ -r ${DSP_IDENTITY_FILE} ]
    then
        grep -v ^\$ ${DSP_IDENTITY_FILE}
        status=$?
    else
        echo "error:file_not_found"
    fi
    echo "</dsp_identity_file>"

    echo "<details>"
    echo "oracle_sid:${ORACLE_SID}"
    echo "oracle_home:${ORACLE_HOME}"
    echo "alert_log:${ALERTLOG}"
    echo "password_file:${ORAPW_FILE}"
    echo "db_name:${NAME}"
    echo "db_unique_name:${DB_UNIQUE_NAME}"
    echo "instance_name:${INSTANCE_NAME}"
    echo "created:${CREATED}"
    echo "startup_time:${STARTUP_TIME}"
    echo "dbid:${DBID}"
    echo "nls_charset:${NLS_CHARACTERSET}"
    echo "nls_nchar_charset:${NLS_NCHAR_CHARACTERSET}"
    echo "cluster_database:${CLUSTER_DATABASE}"
    echo "dbsize_gb:${DBSIZE_GB}"
    echo "cdb:${CDB}"
    echo "edition:${EDITION}"
    echo "database_status:${DATABASE_STATUS}"
    
    if [ "${VERSION_FULL}" != "" ]	# version_full only in versions from about 11g onwards
    then
        VERSION=${VERSION_FULL}
    fi
    echo "version:${VERSION}"
    echo "open_mode:${OPEN_MODE}"
    echo "tde:check_not_implemented"
    echo "last_successful_bkup:check_not_implemented"
    echo "current_scn:${CURRENT_SCN}"
    echo "log_mode:${LOG_MODE}"
    echo "flashback_on:${FLASHBACK_ON}"
    echo "force_logging:${FORCE_LOGGING}"
    echo "supplemental_log_data_min:${SUPPLEMENTAL_LOG_DATA_MIN}"
    
    echo "number_of_standby_dest:${NUMBER_OF_STANDBY_DEST}"
