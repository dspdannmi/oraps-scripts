      #grep ^PDB: ${tmpfile}.pdbs | cut -d: -f2- | sed -e "s/^/${padding}/" -e "s/^$//" | awk -F: '{printf "%20s%s%s%s",$1, $2, $3, $4}'

      (
      echo "CON_ID CON_NAME                       OPEN MODE  RESTRICTED     SIZE(Mb)"
