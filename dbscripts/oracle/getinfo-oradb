    echo "database_role:${DATABASE_ROLE}"
    echo "protection_mode:${PROTECTION_MODE}"
    echo "protection_level:${PROTECTION_LEVEL}"
    
    echo "active_status:${ACTIVE_STATE}"
    echo "instance mode:${INSTANCE_MODE}"
    echo "family:${FAMILY}"
    echo "database_type:${DATABASE_TYPE}"
    
    echo "<pdbs>"
    grep ^PDB: ${tmpfile}.pdbs | cut -d: -f2-
    echo "</pdbs>"

    echo "<details>"

    echo "</getinfo:oracle_database>"
    }


